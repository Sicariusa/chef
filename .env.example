############################
# Frontend (Vite) env vars #
############################

# Convex deployment URL used by the Remix/Vite app.
VITE_CONVEX_URL=https://your-convex-deployment.convex.cloud

# Public WorkOS configuration (safe for the browser).
VITE_WORKOS_CLIENT_ID=client_xxxxx
VITE_WORKOS_API_HOSTNAME=apiauth.convex.dev

# Optional: Convex dashboard host and provisioning feature flag for the UI.
VITE_DASHBOARD_HOST=https://dashboard.convex.dev
VITE_ENABLE_CONVEX_PROVISIONING=false

#########################
# Remix server env vars #
#########################

# URL used by WorkOS to redirect back after sign-in.
WORKOS_REDIRECT_URI=https://your-app.com/auth/callback

# Optional: redirect URI used in development (overrides branch URL).
VITE_WORKOS_REDIRECT_URI=http://127.0.0.1:5173

#########################
# Convex deployment env #
#########################

# Convex control-plane / provisioning host.
PROVISION_HOST=https://api.convex.dev
BIG_BRAIN_HOST=https://api.convex.dev

# Convex OAuth application for project provisioning (server-side only).
CONVEX_OAUTH_CLIENT_ID=oauth_client_id_here
CONVEX_OAUTH_CLIENT_SECRET=super-secret-oauth-client-secret

# WorkOS client ID used by convex/auth.config.ts (same as VITE_WORKOS_CLIENT_ID).
WORKOS_CLIENT_ID=client_xxxxx

# Enable/disable Convex project provisioning.
ENABLE_CONVEX_PROVISIONING=false

##########################
# Optional provider keys #
##########################

# Uncomment and set as needed for code generation.
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...
# OPENAI_API_KEY=sk-...
# XAI_API_KEY=...
# OPENROUTER_API_KEY=...

